{
  "name": "lupine-template-responsive-starter",
  "webEntryPoints": [
    {
      "index": "web/src/index.tsx",
      "html": "web/src/index.html",
      "outdir": "/"
    },
    {
      "index": "web/src/lupine-template-responsive-starter/index.tsx",
      "html": "web/src/lupine-template-responsive-starter/index.html",
      "outdir": "/lupine-template-responsive-starter"
    }
  ],
  "apiEntryPoint": "api/src/index.ts",
  "copyFiles": [
    {
      "env": "all",
      "from": "web/assets",
      "to": "web/assets"
    },
    {
      "env": "all",
      "from": "web/src/lupine-template-responsive-starter/404.html",
      "to": "web/lupine-template-responsive-starter/404.html"
    },
    {
      "env": "all",
      "from": "api/resources",
      "to": "data/resources"
    }
  ]
}