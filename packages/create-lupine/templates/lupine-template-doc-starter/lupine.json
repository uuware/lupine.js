{
  "name": "lupine-template-doc-starter",
  "markdownEntryPoints": {
    "indir": "web/markdown",
    "outdir": "web/src/markdown-built"
  },
  "webEntryPoints": [
    {
      "index": "web/src/index.tsx",
      "html": "web/src/index.html",
      "outdir": "/"
    },
    {
      "index": "web/src/lupine-template-doc-starter/index.tsx",
      "html": "web/src/lupine-template-doc-starter/index.html",
      "outdir": "/lupine-template-doc-starter"
    }
  ],
  "apiEntryPoint": "api/src/index.ts",
  "watchFiles": [
    "web/markdown/**/*.md"
  ],
  "copyFiles": [
    {
      "env": "all",
      "from": "web/assets",
      "to": "web/assets"
    },
    {
      "env": "all",
      "from": "web/src/lupine-template-doc-starter/404.html",
      "to": "web/lupine-template-doc-starter/404.html"
    },
    {
      "env": "all",
      "from": "api/resources",
      "to": "data/resources"
    }
  ]
}