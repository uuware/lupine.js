{
  "name": "demo.app",
  "webEntryPoints": [
    {
      "index": "web/src/index.tsx",
      "html": "web/src/index.html",
      "outdir": "/"
    },
    {
      "index": "web/src/admin_dev/index.tsx",
      "html": "web/src/admin_dev/index.html",
      "outdir": "/admin_dev"
    }
  ],
  "apiEntryPoint": "api/src/index.ts",
  "watchFiles": [
    "web/icons-font.config.js"
  ],
  "copyFiles": [
    {
      "env": "all",
      "from": "web/assets",
      "to": "web/assets"
    },
    {
      "env": "all",
      "from": "api/resources",
      "to": "data/resources"
    }
  ]
}